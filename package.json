{
  "name": "farmad-backend",
  "version": "2.0.0",
  "description": "FarmAd Kenya - Agricultural Marketplace API (PostgreSQL)",
  "main": "src/server.js",
  "scripts": {
    "start":       "node src/server.js",
    "dev":         "nodemon src/server.js",
    "seed":        "node seed.js",
    "seed:prices": "node seed-prices.js",
