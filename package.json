  },
  "dependencies": {
    "express":    "^4.18.2",
    "pg":         "^8.11.3",
    "bcryptjs":   "^2.4.3",
    "jsonwebtoken":"^9.0.2",
    "cors":       "^2.8.5",
    "dotenv":     "^16.3.1",
    "uuid":       "^9.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
